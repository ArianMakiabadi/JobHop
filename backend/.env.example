# Database
APP_DB=mongodb://localhost:27017/your-db

# Auth / Cookies
ACCESS_TOKEN_SECRET_KEY=your_access_secret
REFRESH_TOKEN_SECRET_KEY=your_refresh_secret
COOKIE_PARSER_SECRET_KEY=your_cookie_secret

# Twilio Verify (preferred)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_VERIFY_SID=VAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional: if you prefer to send raw SMS messages instead of using Verify
TWILIO_FROM=+12025550123

# App config
SERVER_URL=http://localhost:5001
CLIENT_URL=http://localhost:3000
NODE_ENV=development
PORT=5001
ALLOW_CORS_ORIGIN=http://localhost:3000
DOMAIN=localhost
IS_TESTING_MODE_OTP=true
